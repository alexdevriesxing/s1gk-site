/*
  X-Content-Type-Options: nosniff
  X-Frame-Options: DENY
  Referrer-Policy: strict-origin-when-cross-origin
  Permissions-Policy: camera=(), microphone=(), geolocation=()
  Cross-Origin-Opener-Policy: same-origin

# Images and SVGs have stable content — safe to pin for a year.
/assets/img/*
  Cache-Control: public, max-age=31536000, immutable
/assets/svg/*
  Cache-Control: public, max-age=31536000, immutable

# CSS/JS use stable (unversioned) filenames, so they must revalidate instead of
# being pinned immutable — otherwise edits never reach the edge or browsers.
# Bump the ?v= query in the HTML when you want an instant cache bust.
/assets/css/*
  Cache-Control: public, max-age=0, must-revalidate
/assets/js/*
  Cache-Control: public, max-age=0, must-revalidate

/*.html
  Cache-Control: public, max-age=0, must-revalidate

/sitemap.xml
  Content-Type: application/xml; charset=utf-8
